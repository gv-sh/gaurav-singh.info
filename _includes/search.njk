<!DOCTYPE html>
<html lang="en">
    {% include "head.njk" %}
    <body>
        <!-- Header -->
        {% include "header.njk" %}

        <!-- Sidebar -->
        {% include "sidebar.njk" %}

        <!-- Main content -->
        <main>
            <input type="text" id="search-input" placeholder="Search..." required oninput="showResults(this.value)">
            <div class="spacer"></div>
            <div id="search-results"></div>

            <script>
                // Gather search results from all available collections, with safe defaults
                const searchResults = [];
                {% if collections.all and collections.all.length %}
                    {% for entry in collections.all %}
                        searchResults.push({
                            title: "{{ entry.data.title | default('No title available') | escape }}",
                            url: "{{ entry.url | default('#') }}",
                            excerpt: "{{ entry.data.description | default('No description available') | truncate(100) | escape }}",
                            content: "{{ entry.templateContent | replace('\n', '') | default('') | escape }}"
                        });
                    {% endfor %}
                {% else %}
                    console.log('No collections found');
                {% endif %}

                // Function to show filtered results based on search input
                function showResults(query) {
                    if (query.length === 0) {
                        document.getElementById("search-results").innerHTML = "";
                        return;
                    }
                    const filteredResults = searchResults.filter(result => 
                        (result.title || "").toLowerCase().includes(query.toLowerCase()) || 
                        (result.content || "").toLowerCase().includes(query.toLowerCase()) ||
                        (result.excerpt || "").toLowerCase().includes(query.toLowerCase()) 
                    );
                    
                    let resultsHtml = "<h4>Search Results:</h4>";
                    filteredResults.forEach(result => {
                        resultsHtml += `<a href="${result.url || '#'}">${result.title || 'No Title'}</a><p>${result.excerpt || ''}</p>`;
                    });

                    resultsHtml += "</div>";
                    
                    document.getElementById("search-results").innerHTML = filteredResults.length ? resultsHtml : "<p>No results found.</p>";
                }
            </script>
        </main>

        <!-- Footer -->
        {% include "footer.njk" %}
    </body>
</html>