<aside>
			<ul>{% for collection in collections.all %}
				{% if collection.data.sidebar %}<li>{% if collection.data.emoji %}{{ collection.data.emoji }}{% endif %} <a {% if page.url == collection.url %}class="active"{% endif %} href="{{ collection.url }}">{{ collection.data.title }}</a></li>{% endif %}
			{% endfor %}</ul>
		</aside>